generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AboutSection {
  id         String  @id @default("about")
  label      String
  heading    String
  paragraph  String
  image1Url  String
  image2Url  String
  buttonText String
  is_active  Boolean @default(true)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AdminUser {
  id        String    @id @default(uuid())
  email     String    @unique
  username  String    @unique @default("admin")
  role      String    @default("ADMIN")
  is_active Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  otps      Otp[]
  sessions  Session[]

  @@index([is_active])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model HeroContent {
  id                 String  @id
  label              String
  heading            String
  buttonText         String
  backgroundImageUrl String
  slideOrder         Int
  is_active          Boolean @default(true)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Project {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  category    String
  location    String
  area        String
  year        String
  client      String
  description String
  narrative   String
  heroImage   String
  images      String
  featured    Boolean  @default(false)
  sortOrder   Int      @default(1)
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([is_active, sortOrder])
  @@index([is_active, featured, sortOrder])
}

model Service {
  id          String   @id @default(uuid())
  title       String
  description String
  image       String
  details     String
  sortOrder   Int      @default(1)
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([is_active, sortOrder])
}

model Otp {
  id        String    @id @default(uuid())
  adminId   String
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  codeHash  String // SHA-256 hash of the OTP
  expiresAt DateTime
  // Present for schema uniformity. OTP consumption stays a hard DELETE: a spent
  // code must not survive as a row that one missing filter away is live again.
  is_active Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@index([adminId])
  // Verification looks up (adminId, codeHash) with an expiry bound.
  @@index([adminId, codeHash])
  // OTP issuance rate limit counts rows per admin within a time window.
  @@index([adminId, createdAt])
}

model FailedAttempt {
  id        String   @id @default(uuid())
  email     String
  ip        String?
  // Present for schema uniformity. Clearing attempts after a successful login
  // stays a hard DELETE, so a stale row can never re-lock an account.
  is_active Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([createdAt])
  // Lockout checks always filter on email AND a createdAt window together.
  @@index([email, createdAt])
}

model Session {
  id           String    @id @default(uuid())
  adminId      String
  admin        AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  refreshToken String    @unique
  expiresAt    DateTime
  // Present for schema uniformity. Logout and rotation stay hard DELETEs: a
  // revoked refresh token must leave no row that could still authenticate.
  is_active    Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@index([adminId])
  // Supports periodic pruning of expired sessions.
  @@index([expiresAt])
}

model Testimonial {
  id          String   @id @default(uuid())
  quote       String
  clientName  String
  location    String
  projectType String
  image       String?
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([is_active, createdAt])
}

model TeamMember {
  id        String   @id @default(uuid())
  name      String
  role      String
  image     String
  bio       String
  is_active Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([is_active, createdAt])
}

model ContactSettings {
  id          String   @id @default("contact")
  phone       String
  email       String
  hoursMonFri String
  hoursSat    String
  hoursSun    String
  mapEmbedUrl String
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Enquiry {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String   @default("")
  projectType String
  message     String
  status      String   @default("NEW")
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([is_active, createdAt])
}
